  "feasibility": {
    "mapValue": {
      "fields": {
        "status": {
          "stringValue": "AMBITIEUX"
        },
        "message": {
          "stringValue": "Ce trail de 20km / 1000m D+ est un beau défi. Avec ta VMA de 15.5 km/h, c'est faisable mais attention : 7 semaines pour un trail de 20km est un peu juste. Pas d'entraînement en D+ actuellement pour 1000m de dénivelé — à travailler. VMA estimée (pas de chrono validé) : l'évaluation comporte une marge d'incertitude. Suis le plan avec rigueur et régularité, c'est la clé pour y arriver."
        },
        "safetyWarning": {
          "stringValue": "Écoute ton corps à chaque séance. Si tu ressens des douleurs inhabituelles, n'hésite pas à adapter ou sauter une séance."
        }
      }
    }
