  { cat: 'DÉB 0km', n: 'Déb 0km Marathon 16sem', p: { isTrail:false, distanceKm:42, planWeeks:16, currentVolume:0, currentElev:0, level:'Débutant (0-1 an)', hasChrono:false }, exp: 'PASS R2' },
  { cat: 'DÉB 0km', n: 'Déb 0km Trail 10/300 8sem', p: { isTrail:true, distanceKm:10, raceDplus:300, planWeeks:8, currentVolume:0, currentElev:0, level:'Débutant (0-1 an)', hasChrono:false }, exp: 'gate2bis (D+ actuel=0 raceDplus<500 → skip)' },
  { cat: 'DÉB 0km', n: 'Déb 0km Trail 25/1500 16sem', p: { isTrail:true, distanceKm:25, raceDplus:1500, planWeeks:16, currentVolume:0, currentElev:0, level:'Débutant (0-1 an)', hasChrono:false }, exp: 'gate2bis pen-15 (D+actuel=0, raceDplus>=500)' },
  { cat: 'DÉB 0km', n: 'Déb 0km Trail 50/3000 20sem (irréaliste extrême)', p: { isTrail:true, distanceKm:50, raceDplus:3000, planWeeks:20, currentVolume:0, currentElev:0, level:'Débutant (0-1 an)', hasChrono:false }, exp: 'IRR via gate1 (D+ cycle débutant capé 800/sem)' },

  // ─── EXPERT + D+ IMPORTANT ───
  { cat: 'EXP D+++', n: 'Exp v50 D1500 Trail 100/5000 24sem chrono', p: { isTrail:true, distanceKm:100, raceDplus:5000, planWeeks:24, currentVolume:50, currentElev:1500, level:'Expert (Performance)', hasChrono:true }, exp: 'PASS (Bug 2 fix coef 0.50 ultra)' },
  { cat: 'EXP D+++', n: 'Exp v70 D2500 Trail 170/10000 30sem (UTMB)', p: { isTrail:true, distanceKm:170, raceDplus:10000, planWeeks:30, currentVolume:70, currentElev:2500, level:'Expert (Performance)', hasChrono:true }, exp: 'PASS attendu' },
  { cat: 'EXP D+++', n: 'Exp v30 D500 Trail 80/4000 16sem (vol insuffisant)', p: { isTrail:true, distanceKm:80, raceDplus:4000, planWeeks:16, currentVolume:30, currentElev:500, level:'Expert (Performance)', hasChrono:true }, exp: 'gate2 ratio 8× OK / gate3 vol 30/80=0.37>0.30 OK / probable gate1' },
  { cat: 'EXP D+++', n: 'Exp v40 D800 Trail 60/3500 18sem', p: { isTrail:true, distanceKm:60, raceDplus:3500, planWeeks:18, currentVolume:40, currentElev:800, level:'Expert (Performance)', hasChrono:true }, exp: 'check ratios' },

  // ─── EXPERT + D+ MINIME (route ou trail très plat) ───
  { cat: 'EXP D+min', n: 'Exp v50 D0 Marathon 16sem chrono', p: { isTrail:false, distanceKm:42, planWeeks:16, currentVolume:50, currentElev:0, level:'Expert (Performance)', hasChrono:true }, exp: 'PASS (route, gate6 skip vol≥40)' },
  { cat: 'EXP D+min', n: 'Exp v60 D100 Trail 30/200 12sem chrono', p: { isTrail:true, distanceKm:30, raceDplus:200, planWeeks:12, currentVolume:60, currentElev:100, level:'Expert (Performance)', hasChrono:true }, exp: 'PASS' },
  { cat: 'EXP D+min', n: 'Exp v40 D50 Trail 15/300 10sem chrono', p: { isTrail:true, distanceKm:15, raceDplus:300, planWeeks:10, currentVolume:40, currentElev:50, level:'Expert (Performance)', hasChrono:true }, exp: 'PASS (ratio D+ 6× OK, vol 2.67× race OK)' },

  // ─── VOLUME KM IMPORTANT (>50 km/sem) ───
  { cat: 'VOL+++', n: 'Inter v60 D200 Marathon 16sem chrono', p: { isTrail:false, distanceKm:42, planWeeks:16, currentVolume:60, currentElev:200, level:'Intermédiaire (Régulier)', hasChrono:true }, exp: 'PASS' },
  { cat: 'VOL+++', n: 'Conf v80 D1000 Trail 50/3000 20sem chrono', p: { isTrail:true, distanceKm:50, raceDplus:3000, planWeeks:20, currentVolume:80, currentElev:1000, level:'Confirmé (Compétition)', hasChrono:true }, exp: 'PASS attendu' },
  { cat: 'VOL+++', n: 'Inter v100 D500 Semi 12sem chrono', p: { isTrail:false, distanceKm:21, planWeeks:12, currentVolume:100, currentElev:500, level:'Intermédiaire (Régulier)', hasChrono:true }, exp: 'PASS' },

  // ─── VOLUME KM FAIBLE (<10 km/sem) ───
  { cat: 'VOL---', n: 'Inter v5 D0 Marathon 16sem (ambitieux)', p: { isTrail:false, distanceKm:42, planWeeks:16, currentVolume:5, currentElev:0, level:'Intermédiaire (Régulier)', hasChrono:false }, exp: 'gate4 saut 5→5.5 OK / pas dautre gate route' },
  { cat: 'VOL---', n: 'Inter v8 D100 Trail 20/1500 10sem', p: { isTrail:true, distanceKm:20, raceDplus:1500, planWeeks:10, currentVolume:8, currentElev:100, level:'Intermédiaire (Régulier)', hasChrono:false }, exp: 'gate2 ratio 15× → vigilance / gate3 vol 8/20=0.40<0.50 IRR' },
  { cat: 'VOL---', n: 'Déb v3 D50 Semi 16sem (vraiment irréaliste)', p: { isTrail:false, distanceKm:21, planWeeks:16, currentVolume:3, currentElev:50, level:'Débutant (0-1 an)', hasChrono:false }, exp: 'gate4 OK petit saut. R2 PASS, autre garde-fou agit.' },

