{
  "firestore": {
    "rules": "firestore.rules"
  },
  "hosting": {
    "public": "dist",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "redirects": [
      {
        "source": "/post/:slug",
        "destination": "/blog/:slug",
        "type": 301
      },
      {
        "source": "/tarifs",
        "destination": "/pricing",
        "type": 301
      },
      {
        "source": "/lexique",
        "destination": "/glossary",
        "type": 301
      },
      {
        "source": "/tools",
        "destination": "/outils",
        "type": 301
      },
      {
        "source": "/mentions_l_gales",
        "destination": "/mentions-legales",
        "type": 301
      },
      {
        "source": "/contact",
        "destination": "/",
        "type": 301
      }
    ],
    "headers": [
      {
        "source": "/assets/**",
        "headers": [
          { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
        ]
      },
      {
        "source": "**/*.{js,css}",
        "headers": [
          { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
        ]
      },
      {
        "source": "!(assets/**|**/*.js|**/*.css|**/*.png|**/*.jpg|**/*.svg|**/*.ico|**/*.webp|**/*.woff2)",
        "headers": [
          { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
        ]
      }
    ],
    "rewrites": [
      {
        "source": "/api/**",
        "run": {
          "serviceId": "coach-running-backend",
          "region": "europe-west1"
        }
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}
