  { cat: 'COMBO', n: 'Inter v15 D50 Trail 50/3000 11sem (Peterson-like)', p: { isTrail:true, distanceKm:50, raceDplus:3000, planWeeks:11, currentVolume:15, currentElev:50, level:'Intermédiaire (Régulier)', hasChrono:false }, exp: 'IRR gate2 (60×) + gate3 (vol 15/50=0.30<0.40 IRR) ; pas de gate6 car pas Expert' },
  { cat: 'COMBO', n: 'Conf v20 D200 Trail 80/3500 14sem', p: { isTrail:true, distanceKm:80, raceDplus:3500, planWeeks:14, currentVolume:20, currentElev:200, level:'Confirmé (Compétition)', hasChrono:true }, exp: 'gate2 ratio 17× pen-10 / gate3 vol 0.25<0.30 IRR' },

  // ─── EXPERT NON VALIDÉ (Bug 3 contexts variés) ───
  { cat: 'EXP_NV', n: 'Expert vol 35 sans chrono semi route', p: { isTrail:false, distanceKm:21, planWeeks:12, currentVolume:35, currentElev:0, level:'Expert (Performance)', hasChrono:false }, exp: 'gate6 pen -20' },
  { cat: 'EXP_NV', n: 'Expert vol 40 (frontière) sans chrono', p: { isTrail:false, distanceKm:21, planWeeks:12, currentVolume:40, currentElev:0, level:'Expert (Performance)', hasChrono:false }, exp: 'PASS (vol >= 40 → gate6 skip)' },
  { cat: 'EXP_NV', n: 'Expert vol 35 AVEC chrono', p: { isTrail:false, distanceKm:21, planWeeks:12, currentVolume:35, currentElev:0, level:'Expert (Performance)', hasChrono:true }, exp: 'PASS (gate6 skip car chrono)' },

  // ─── EDGE CASES ───
  { cat: 'EDGE', n: 'planWeeks=2 trail (très court)', p: { isTrail:true, distanceKm:20, raceDplus:1000, planWeeks:2, currentVolume:25, currentElev:600, level:'Intermédiaire (Régulier)', hasChrono:true }, exp: 'gate1 probable (cycle 2 sem insuffisant)' },
  { cat: 'EDGE', n: 'level=undefined ne crash pas', p: { isTrail:false, distanceKm:21, planWeeks:12, currentVolume:30, currentElev:0, level:undefined, hasChrono:false }, exp: 'crash possible si level undefined' },
];

console.log('═'.repeat(140));
console.log(`  TEST MATRICE R2 — ${profils.length} profils diversifiés`);
console.log('═'.repeat(140));
const stats = { pass: 0, irr: 0, pen: 0, crash: 0 };
let lastCat = '';
for (const t of profils) {
  if (t.cat !== lastCat) {
    console.log(`\n\n── ${t.cat} ──`);
    lastCat = t.cat;
  }
  try {
    const r = simulateE2E(t.p);
    const verdict = r.irrealisticCap !== undefined ? `🔴 IRR(${r.irrealisticCap})` : r.scorePenalty > 0 ? `🟡 pen-${r.scorePenalty}` : '✅ PASS';
    if (r.irrealisticCap !== undefined) stats.irr++;
    else if (r.scorePenalty > 0) stats.pen++;
    else stats.pass++;
    console.log(`  ${verdict.padEnd(15)} ${t.n}`);
    if (r.reasons.length) console.log(`                 → ${r.reasons.join(' | ')}`);
    console.log(`                 attendu: ${t.exp}`);
  } catch (e) {
    stats.crash++;
    console.log(`  💥 CRASH        ${t.n}`);
    console.log(`                 ${e.message}`);
  }
}
console.log(`\n${'═'.repeat(140)}`);
console.log(`  RÉCAP : ${stats.pass} PASS | ${stats.pen} pen | ${stats.irr} IRR | ${stats.crash} CRASH`);
console.log('═'.repeat(140));
